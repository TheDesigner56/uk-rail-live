{
  "builds": [
    {
      "src": "ukrail/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12",
        "buildCommand": "bash build.sh",
        "includeFiles": "staticfiles/**,rail/fixtures/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/ukrail/wsgi.py" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "ukrail.settings",
    "VERCEL": "1"
  }
}