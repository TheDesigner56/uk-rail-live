{
  "builds": [
    {
      "src": "ukrail/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "/ukrail/wsgi.py" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "ukrail.settings"
  }
}