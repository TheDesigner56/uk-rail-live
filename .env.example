# UK Rail Live — Environment Variables

# Django
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon Postgres with PostGIS — leave empty for sqlite local dev)
# Format: postgres://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# Darwin API (register at raildata.org.uk)
DARWIN_API_KEY=
DARWIN_API_URL=https://api1.raildata.org.uk/1010-knowledge1_1-rti